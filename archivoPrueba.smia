#!/bin/bash 
# Calificación Proyecto 1 
# 1S 2026 
# Cambiar "su_usuario" -> por el usuario de su distribución de linux  
# Cambiar "34" -> por los últimos dos dígitos de su carnet  

#----------------- 1. MKDISK -----------------
#----------------- MKDISK CON ERROR -----------------
# ERROR PARAMETROS
mkdisk -param=x -size=30 -path=/home/josegar/Calificacion_MIA/Discos/DiscoN.mia
mkdisk -tamaño=3000 -unit=K -path=/home/josegar/Calificacion_MIA/Discos/DiscoN.mia

#----------------- CREACION DE DISCOS -----------------
# 50M A
mkdisk -size=50 -unit=M -fit=FF -path=/home/josegar/Calificacion_MIA/Discos/Disco1.mia
# 50M B
mkdisk -unit=k -size=51200 -fit=BF -path=/home/josegar/Calificacion_MIA/Discos/Disco2.mia
# 13M C
mkdisk -size=13 -path=/home/josegar/Calificacion_MIA/Discos/Disco3.mia
# 50M D
mkdisk -size=51200 -unit=K -path=/home/josegar/Calificacion_MIA/Discos/Disco4.mia
# 20M E
mkdisk -size=20 -unit=M -fit=WF -path=/home/josegar/Calificacion_MIA/Discos/Disco5.mia

# 50M F X
mkdisk -size=50 -unit=M -fit=FF -path=/home/josegar/Calificacion_MIA/Discos/Disco6.mia
# 50M G X
mkdisk -size=50 -unit=M -fit=FF -path=/home/josegar/Calificacion_MIA/Discos/Disco7.mia
# 50M H X
mkdisk -size=51200 -unit=K -path=/home/josegar/Calificacion_MIA/Discos/Disco8.mia
# 50M I X
mkdisk -size=51200 -unit=K -path=/home/josegar/Calificacion_MIA/Discos/Disco9.mia
# 50M J X
mkdisk -size=51200 -unit=K -path=/home/josegar/Calificacion_MIA/Discos/Disco10.mia

mkdisk -size=100 -unit=M -fit=FF -path=/home/josegar/Calificacion_MIA/Discos/Disco11.mia
mkdisk -size=75 -unit=M -fit=BF -path=/home/josegar/Calificacion_MIA/Discos/Disco12.mia

#-----------------2. RMDISK-----------------
#ERROR DISCO NO EXISTE
rmdisk -path=/home/josegar/Calificacion_MIA/Discos/DiscoN.mia

# BORRANDO DISCOS
rmdisk -path=/home/josegar/Calificacion_MIA/Discos/Disco6.mia
rmdisk -path=/home/josegar/Calificacion_MIA/Discos/Disco7.mia
rmdisk -path=/home/josegar/Calificacion_MIA/Discos/Disco8.mia
rmdisk -path=/home/josegar/Calificacion_MIA/Discos/Disco9.mia
rmdisk -path=/home/josegar/Calificacion_MIA/Discos/Disco10.mia
rmdisk -path=/home/josegar/Calificacion_MIA/Discos/Disco12.mia

#-----------------3. FDISK-----------------
#-----------------CREACION DE PARTICIONES-----------------
#DISCO 1
# ERROR RUTA NO ENCONTRADA
fdisk -type=P -unit=b -name=PartErr -size=10485760 -path=/home/josegar/Calificacion_MIA/Discos/DiscoN.mia -fit=BF  

# PRIMARIA 10M
fdisk -type=P -unit=b -name=Part11 -size=10485760 -path=/home/josegar/Calificacion_MIA/Discos/Disco1.mia -fit=BF
fdisk -type=P -unit=k -name=Part12 -size=10240 -path=/home/josegar/Calificacion_MIA/Discos/Disco1.mia -fit=BF
fdisk -type=P -unit=M -name=Part13 -size=10 -path=/home/josegar/Calificacion_MIA/Discos/Disco1.mia -fit=BF
fdisk -type=P -unit=b -name=Part14 -size=10485760 -path=/home/josegar/Calificacion_MIA/Discos/Disco1.mia -fit=BF

#ERR LIMITE PARTICION PRIMARIA
fdisk -type=P -unit=b -name=PartErr -size=10485760 -path=/home/josegar/Calificacion_MIA/Discos/Disco1.mia -fit=BF

#DISCO 3
# ERROR FALTA ESPACIO
fdisk -type=P -unit=m -name=PartErr -size=20 -path=/home/josegar/Calificacion_MIA/Discos/Disco3.mia
fdisk -type=P -unit=m -name=Part31 -size=4 -path=/home/josegar/Calificacion_MIA/Discos/Disco3.mia
fdisk -type=P -unit=m -name=Part32 -size=4 -path=/home/josegar/Calificacion_MIA/Discos/Disco3.mia
fdisk -type=P -unit=m -name=Part33 -size=1 -path=/home/josegar/Calificacion_MIA/Discos/Disco3.mia

#DISCO 2
fdisk -type=P -unit=M -name=Part21 -size=10 -path=/home/josegar/Calificacion_MIA/Discos/Disco2.mia -fit=FF
fdisk -type=E -unit=M -name=Part22 -size=20 -path=/home/josegar/Calificacion_MIA/Discos/Disco2.mia -fit=FF
fdisk -type=L -unit=M -name=Part23 -size=5 -path=/home/josegar/Calificacion_MIA/Discos/Disco2.mia -fit=FF
fdisk -type=L -unit=M -name=Part24 -size=5 -path=/home/josegar/Calificacion_MIA/Discos/Disco2.mia -fit=FF

fdisk -type=P -unit=M -name=Part11_1 -size=25 -path=/home/josegar/Calificacion_MIA/Discos/Disco11.mia -fit=BF
fdisk -type=P -unit=M -name=Part11_2 -size=25 -path=/home/josegar/Calificacion_MIA/Discos/Disco11.mia -fit=BF

#-----------------MOUNT-----------------
mount -path=/home/josegar/Calificacion_MIA/Discos/Disco1.mia -name=Part11
mount -path=/home/josegar/Calificacion_MIA/Discos/Disco1.mia -name=Part12

mount -path=/home/josegar/Calificacion_MIA/Discos/Disco1.mia -name=Part11

mount -path=/home/josegar/Calificacion_MIA/Discos/Disco3.mia -name=Part0
mount -path=/home/josegar/Calificacion_MIA/Discos/Disco3.mia -name=Part31
mount -path=/home/josegar/Calificacion_MIA/Discos/Disco3.mia -name=Part32

mount -path=/home/josegar/Calificacion_MIA/Discos/Disco2.mia -name=Part21
mount -path=/home/josegar/Calificacion_MIA/Discos/Disco2.mia -name=Part23
mount -path=/home/josegar/Calificacion_MIA/Discos/Disco11.mia -name=Part11_1

#-----------------REPORTES-----------------
rep -id=A661 -Path=/home/josegar/Calificacion_MIA/Reportes/p1_rE.jpg -name=mbr

rep -id=661A -Path=/home/josegar/Calificacion_MIA/Reportes/p1_r1_disk.jpg -name=disk
rep -id=661B -Path=/home/josegar/Calificacion_MIA/Reportes/p1_r3_disk.jpg -name=disk
rep -id=661C -Path=/home/josegar/Calificacion_MIA/Reportes/p1_r5_disk.jpg -name=disk
rep -id=661D -Path=/home/josegar/Calificacion_MIA/Reportes/p1_r6_disk.jpg -name=disk

rep -id=661A -Path=/home/josegar/Calificacion_MIA/Reportes/p1_r2_mbr.jpg -name=mbr
rep -id=662B -Path=/home/josegar/Calificacion_MIA/Reportes/p1_r4_mbr.jpg -name=mbr
rep -id=661C -Path=/home/josegar/Calificacion_MIA/Reportes/p1_r7_mbr.jpg -name=mbr

#-----------------MKFS-----------------
mkfs -type=full -id=661A
mkfs -type=full -id=661C
mkfs -type=full -id=661D